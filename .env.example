# Public site URL — used for canonical URLs, sitemap, Open Graph.
NEXT_PUBLIC_SITE_URL=https://www.minasalama.com

# Business contact details surfaced in the UI (safe to be public).
NEXT_PUBLIC_CONTACT_EMAIL=hello@minasalama.com
NEXT_PUBLIC_CONTACT_PHONE=+201000000000
NEXT_PUBLIC_WHATSAPP_NUMBER=201000000000

# --- Server-only secrets (never exposed to the browser) ---
# Where inquiry submissions are delivered. Leave blank in dev to log to console.
INQUIRY_NOTIFY_EMAIL=
# Example transactional email provider key (set when wiring real delivery).
EMAIL_API_KEY=

# --- Admin dashboard ---
# Password to log into /admin. Choose a strong value.
ADMIN_PASSWORD=
# Secret used to sign the admin session cookie. Use a long random string
# (e.g. `openssl rand -hex 32`).
AUTH_SECRET=

# --- Supabase (database + image storage) ---
# From Supabase: Project Settings → API. Service role key is SERVER-ONLY.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Public Storage bucket that holds uploaded product images.
SUPABASE_STORAGE_BUCKET=product-images
